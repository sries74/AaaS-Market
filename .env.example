# =============================================================================
# AaaS Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ---- App ----
DEBUG=false
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Auth ----
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_strong_random_secret

# ---- Database ----
POSTGRES_USER=aaas
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=aaas_db
DATABASE_URL=postgresql+asyncpg://aaas:CHANGE_ME_strong_password@postgres:5432/aaas_db

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
